const newApi="http://localhost:55801/api/HomePage/GetNewArrival";
const cartApi="http://localhost:55801/api/Cart";


///For HOME PAGE New Arrivals
//display function 
function displayNew() {
    let container = document.getElementById("newArrival"); 
    let htmlContent = "";
    $.ajax({
        url:newApi,
        type:"GET",
        success:(newArrival)=>{
            newArrival.forEach((item, index) => {
        htmlContent += `
        <div class="imges">
            <img src="${item.Image}" alt="${item.ProdName}" loading="lazy">
            <div class="imgprop">
                <p class="img-description">${item.Description}</p>
                <div class="star-container">⭐⭐⭐⭐⭐</div>
                <div><i class="fa-solid fa-indian-rupee-sign"></i> ${item.Price}.00</div>
                <button class="btn-add" onclick="addToCart(${item.ProdID})">Add To Cart</button>
            </div>
        </div>
        `;
        })
        container.innerHTML = htmlContent; // Inject HTML dynamically

    },
    error:(err)=>{
          console.log(" Error: "+err);
    }
        
    });
}
function insertCart(product){
     $.ajax({
        url:cartApi,
        type:"POST",
        contentType:"application/json",
        data:JSON.stringify({
            UserEmail: sessionStorage.getItem('userEmail'),
            ProdID: product.ProdID,
            Qty: 1,
            Price: product.Price
        }),
          success: () => alert("Product Addeed to Cart!!"),
        error: (err) => console.log(err)

    });

}
function updateCart(item){
    $.ajax({
        url: cartApi,
        type: "PUT",
        contentType: "application/json",
        data: JSON.stringify(item),
        success: () => alert("Product Added to Cart!!"),
        error: (err) => console.log(err)
    });
}
function addToCart(index,items) {
   
    const product = items[index];
        var userID = sessionStorage.getItem('userEmail');
                if (userID) {
                    $.ajax({
                        url:cartApi+"/"+userID,
                        type:"GET",
                        success:(cart)=>{ 
                            let existing = cart.find(c =>c.UserName == userID && c.ProdID == product.ProdID);
                                if (existing) {
                                    //  update
                                    existing.Qty += 1;
                                    existing.Price = existing.Qty * product.Price;
                                    updateCart(existing);
                                } else {
                                    //  insert
                                    insertCart(product);
                                }
                            },
                        error:(err) => console.log(err)
                });
                }else{
                    alert('User not logged in ');
                    // Navigate to a new page
                    window.location.href = './Login.html';
                    return; // Exit if UserID is not set
                }
            }
                


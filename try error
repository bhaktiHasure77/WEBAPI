using System;
using System.Collections.Generic;
using System.Configuration;
using System.Data.SqlClient;
using System.Linq;
using System.Net;
using System.Net.Http;
using System.Web.Http;
using WebAPIProject.Models;

namespace WebAPIProject.Controllers
{
    public class CartController : ApiController
    {

        string str = ConfigurationManager.ConnectionStrings["MyCon"].ConnectionString;
        [HttpGet]
        public List<Cart> GetUsers(string name)
        {
            List<Cart> cart = new List<Cart>();
            using (SqlConnection con = new SqlConnection(str))
            {
                string query = @"Select c.*,UserEmail from Cart c Inner Join UserDetails u on c.UserID=u.UserID where u.UserEmail=@name";
               
                SqlCommand cmd = new SqlCommand(query, con);
                cmd.Parameters.AddWithValue("@name", name);
                con.Open();
                SqlDataReader rdr = cmd.ExecuteReader();
                while (rdr.Read())
                {
                    Cart c = new Cart();
                    c.CartID = Convert.ToInt32(rdr["CartID"]);
                    c.UserID = Convert.ToInt32(rdr["UserID"]);
                    c.ProdID = Convert.ToInt32(rdr["ProdID"]);
                    c.Qty = Convert.ToInt32(rdr["CartQty"]);
                    c.Price = Convert.ToInt32(rdr["Price"]);
                    cart.Add(c);
                }
            }
            return cart;
        }
        [HttpPost]
        public string InsertCart(Cart c)
        {
            string res = " ";
            using (SqlConnection con = new SqlConnection(str))
            {
                string query = @"Insert Into Cart(UserID, ProdID,,CartQty,Price) values(@uid,@pid,@qty,@price)";
                SqlCommand cmd = new SqlCommand(query, con);
                cmd.Parameters.AddWithValue("@uid", c.UserID);
                cmd.Parameters.AddWithValue("@pid", c.ProdID);
                cmd.Parameters.AddWithValue("@qty", c.Qty);
                cmd.Parameters.AddWithValue("@price", c.Price);



                con.Open();
                int row = cmd.ExecuteNonQuery();
                if (row > 0)
                {
                    res = "Cart Added!!";
                }
                else
                {
                    res = "Error Inserting Cart!!";
                }

            }

            return res;
        }
        [HttpPut]
        public string UpdateCart(Cart c)
        {
            using (SqlConnection con = new SqlConnection(str))
            {
                string query = @"Update Cart Set UserID=@uid,
                                ProdID=@pid,CartQty=@qty,Price=@price Where CartID=@cid";
                SqlCommand cmd = new SqlCommand(query, con);
                cmd.Parameters.AddWithValue("@cid", c.CartID);
                cmd.Parameters.AddWithValue("@uid", c.UserID);
                cmd.Parameters.AddWithValue("@pid", c.ProdID);                
                cmd.Parameters.AddWithValue("@qty", c.Qty);
                cmd.Parameters.AddWithValue("@price", c.Price);
                con.Open();
                cmd.ExecuteNonQuery();
            }
            return "Cart Updated Successfully!!";
        }
        [HttpDelete]
        public string DeleteCart(int id)
        {
            using (SqlConnection con = new SqlConnection(str))
            {
                string query = "Delete From Cart Where CartID=@id";
                SqlCommand cmd = new SqlCommand(query, con);
                cmd.Parameters.AddWithValue("@id", id);
                con.Open();
                cmd.ExecuteNonQuery();
            }
            return "Cart Deleted Succesfully!!";
        }
    }
}

function updateUserIcon() {
    let userIcon = document.getElementById("user-icon");
    let loggedInUser = JSON.parse(localStorage.getItem("loggedInUser"));

    if (loggedInUser) {
        // LOGOUT ICON
        userIcon.innerHTML = `
            <i class="fa-solid fa-right-from-bracket"
               title="Logout"
               style="cursor:pointer; font-size:22px;"
               onclick="logoutUser()">
            </i>
        `;
    } else {
        //LOGIN ICON
        userIcon.innerHTML = `
            <a href="./LoginPage.html" title="Login">
                <i class="fa-solid fa-right-to-bracket" style="font-size:22px;"></i>
            </a>
        `;
    }
}

function logoutUser() {
    localStorage.removeItem("loggedInUser"); // remove login data
    alert("Logged out successfully!");

    updateUserIcon(); // update navbar instantly

    // Optional: redirect to home page
    window.location.href = "Home.html";
}
